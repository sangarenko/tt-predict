generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Match {
  id          String   @id @default(cuid())
  externalId  String?
  source      String   @default("betboom")
  sport       String   @default("table_tennis")
  league      String?
  tournament  String?
  player1     String
  player2     String
  startTime   DateTime
  status      String   @default("upcoming")
  score1      Int      @default(0)
  score2      Int      @default(0)
  winner      String?
  rawJson     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  odds       BookmakerOdds[]
  aiBets     AiBet[]
  predictions Prediction[]
}

model BookmakerOdds {
  id          String   @id @default(cuid())
  matchId     String
  source      String   @default("betboom")
  odds1       Float?
  odds2       Float?
  totalOver   Float?
  totalUnder  Float?
  handicap1   Float?
  handicap2   Float?
  updatedAt   DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model AiProfile {
  id             String   @id @default(cuid())
  name           String
  emoji          String
  description    String
  color          String
  strategy       String
  isActive       Boolean  @default(true)
  initialAmount  Float    @default(1000)
  currentAmount  Float    @default(1000)
  peakAmount     Float    @default(1000)
  flatAmount     Float    @default(50)
  stopLossPct    Float    @default(30)
  totalBets      Int      @default(0)
  wonBets        Int      @default(0)
  lostBets       Int      @default(0)
  pendingBets    Int      @default(0)
  skippedBets    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  aiBets AiBet[]
}

model AiBet {
  id              String   @id @default(cuid())
  matchId         String
  profileId       String
  player1         String
  player2         String
  predictedWinner String
  confidence      Float
  valueRating     Float    @default(0)
  odds            Float
  stake           Float
  potentialWin    Float
  profit          Float    @default(0)
  status          String   @default("pending")
  reasoning       String?
  strategy        String?
  createdAt       DateTime @default(now())
  settledAt       DateTime?

  match   Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  profile AiProfile @relation(fields: [profileId], references: [id])
}

model Prediction {
  id              String   @id @default(cuid())
  matchId         String
  predictorId     String?
  predictedWinner String?
  confidence      Float?
  strategy        String?
  reasoning       String?
  createdAt       DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model CollectionLog {
  id              String   @id @default(cuid())
  source          String   @default("betboom")
  status          String   @default("success")
  matchesFound    Int      @default(0)
  matchesCollected Int     @default(0)
  matchesNew      Int      @default(0)
  matchesUpdated  Int      @default(0)
  error           String?
  duration        Int      @default(0)
  createdAt       DateTime @default(now())
}

model ValueBet {
  id              String   @id @default(cuid())
  matchId         String
  player1         String
  player2         String
  selection       String
  odds            Float
  impliedProb     Float
  trueProb        Float
  edge            Float
  kellyFraction   Float?
  ev              Float?
  createdAt       DateTime @default(now())
}

model Predictor {
  id               String   @id @default(cuid())
  name             String
  platform         String?
  tier             String   @default("basic")
  accuracy         Float    @default(0)
  totalPredictions Int      @default(0)
  verified         Boolean  @default(false)
  bio              String?
  avatarEmoji      String   @default("🤖")
  followers        Int      @default(0)
  currentStreak    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Tipster {
  id                 String   @id @default(cuid())
  username           String
  displayName        String
  platform           String   @default("telegram")
  avatarUrl          String?
  bio                String   @default("")
  totalPredictions   Int      @default(0)
  wins               Int      @default(0)
  losses             Int      @default(0)
  voids              Int      @default(0)
  deletedBets        Int      @default(0)
  editsAfterPost     Int      @default(0)
  realWinRate        Float    @default(0)
  claimedWinRate     Float    @default(0)
  scamScore          Float    @default(0)
  trustLevel         Int      @default(0)
  profitIfFollowed   Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
